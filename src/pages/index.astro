---
import Layout from '../layouts/Layout.astro';
import CTAWaitlistToggle from '../components/CTAWaitlistToggle.astro';
import VitalsDashboard from '../components/VitalsDashboard.astro';
import KiraDemo from '../components/KiraDemo.astro';
---

<Layout>
  <!-- Hero Section -->
  <section class="relative pt-20 pb-16 md:pt-32 md:pb-28 overflow-hidden">
    <!-- Ambient glow lights in background -->
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-green-accent/5 rounded-full blur-[120px] pointer-events-none"></div>

    <div class="max-w-4xl mx-auto text-center px-6 relative z-10 flex flex-col items-center">
      <!-- Tag badge -->
      <div class="inline-flex items-center gap-1.5 px-3 py-1 bg-white/5 border border-white/10 rounded-full text-xs font-semibold text-gray-300 mb-6 uppercase tracking-wider">
        <span class="w-1.5 h-1.5 rounded-full bg-green-accent"></span>
        SelfHealth App Launch
      </div>

      <!-- Main Headline -->
      <h1 class="font-display font-extrabold text-4xl sm:text-6xl text-white tracking-tight leading-[1.1] mb-6">
        Train smarter. <br class="sm:hidden" />
        Age stronger. <br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-green-accent to-[#4fd1c5] drop-shadow-[0_0_15px_rgba(63,209,122,0.2)]">
          Know what's working.
        </span>
      </h1>

      <!-- Subheadline -->
      <p class="font-sans text-gray-400 text-base sm:text-xl leading-relaxed max-w-2xl mb-10">
        Stop guessing. SelfHealth decodes your raw health metrics—blood panels, biomarkers, sleep consistency, and strength output—into actionable, daily feedback to build and retain muscle, recover faster, and age with strength.
      </p>

      <!-- CTA Toggle Block -->
      <div id="waitlist" class="w-full mb-16">
        <CTAWaitlistToggle />
      </div>
    </div>
  </section>

  <!-- Interactive Mockups Centerpiece Section -->
  <section class="py-16 md:py-24 border-y border-white/5 bg-[#0d0f11]/30">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-display font-bold text-2xl sm:text-4xl text-white mb-4">
          All your vitals. Translated in real-time.
        </h2>
        <p class="text-sm sm:text-base text-gray-400 max-w-xl mx-auto">
          We bring together lab results, sleep data, and workouts. Then we explain exactly what your body is trying to tell you.
        </p>
      </div>

      <!-- Vitals Dashboard Mockup -->
      <div class="mb-20">
        <div class="text-center mb-6">
          <span class="text-[10px] uppercase font-bold tracking-widest text-green-accent">App Preview</span>
          <h3 class="text-lg font-bold text-white mt-1">Universal Vitals Scoring</h3>
        </div>
        <VitalsDashboard />
      </div>

      <!-- Kira AI Assistant Section -->
      <div class="mt-24">
        <div class="text-center mb-8 max-w-lg mx-auto">
          <span class="text-[10px] uppercase font-bold tracking-widest text-green-accent">AI Translation</span>
          <h3 class="text-xl sm:text-2xl font-bold text-white mt-1">Meet Kira: Your Health Translator</h3>
          <p class="text-xs sm:text-sm text-gray-400 mt-2">
            No more medical jargon or anxiety-inducing search results. Upload any blood test PDF and get plain-English guidance instantly.
          </p>
        </div>
        <KiraDemo />
      </div>
    </div>
  </section>

  <!-- Privacy Guarantee Section -->
  <section class="py-16 md:py-24 relative overflow-hidden">
    <div class="max-w-4xl mx-auto px-6 text-center relative z-10">
      <div class="inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-white/3 border border-white/5 text-green-accent mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
      </div>

      <h2 class="font-display font-bold text-2xl sm:text-4xl text-white mb-4">
        Your data. Fully in your control.
      </h2>

      <!-- Privacy statement -->
      <p class="text-sm sm:text-base text-gray-300 max-w-xl mx-auto leading-relaxed mb-6">
        Processes on-device wherever possible, and we tell you clearly any time something needs the cloud.
      </p>

      <p class="text-xs text-gray-500 max-w-md mx-auto">
        We do not sell your health data, and we do not store your private credentials. Security is baked in from the foundation.
      </p>
    </div>
  </section>
</Layout>
