---
import '../../styles/global.css';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// Fetch all markdown posts under src/content/train using Vite import.meta.glob
const postsMap = import.meta.glob('../../content/train/*.md', { eager: true });
const posts = Object.values(postsMap);

// Sort posts by date descending
const sortedPosts = posts.sort((a, b) => {
  return new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime();
});
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <title>Train: Strength & Recovery | Self Health Living</title>
    <meta name="description" content="Explore scientific insights on strength training, muscle retention after 40, recovery protocols, and longevity." />
    <meta name="color-scheme" content="light dark" />
  </head>
  <body class="light-room min-h-screen flex flex-col selection:bg-green-accent selection:text-[#14171a]">
    <Header currentPillar="train" />
    
    <main class="flex-grow py-12 px-6 md:px-12 max-w-6xl mx-auto w-full">
      <!-- Header Section -->
      <div class="border-b border-gray-200 pb-8 mb-12 text-center md:text-left">
        <span class="text-xs font-bold uppercase tracking-widest text-green-accent">Content Pillar</span>
        <h1 class="font-display font-extrabold text-4xl sm:text-5xl text-[#1e2226] mt-2 mb-4">
          Train Smarter. Age Stronger.
        </h1>
        <p class="text-gray-500 text-sm sm:text-base max-w-xl leading-relaxed">
          Daily science-backed guides covering resistance training, muscle retention protocols, metabolic fitness, and sleep recovery.
        </p>
      </div>

      <!-- Articles Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {sortedPosts.map((post) => {
          const { title, date, featured_image, slug } = post.frontmatter;
          const formattedDate = date ? new Date(date).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric'
          }) : '';
          
          return (
            <a 
              href={`/train/${slug}/`}
              class="group flex flex-col bg-white border border-gray-100 rounded-2xl overflow-hidden hover:shadow-xl hover:border-gray-200 transition-all duration-300 hover:-translate-y-1"
            >
              {/* Image */}
              <div class="w-full aspect-[16/10] overflow-hidden bg-gray-50 border-b border-gray-100 relative">
                {featured_image ? (
                  <img 
                    src={featured_image} 
                    alt={title} 
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center text-gray-300 bg-gray-50">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                  </div>
                )}
              </div>
              
              {/* Content */}
              <div class="p-6 flex-grow flex flex-col justify-between">
                <div>
                  <time datetime={date} class="text-[11px] font-bold text-gray-400 uppercase tracking-wider block mb-2">
                    {formattedDate}
                  </time>
                  <h2 class="font-display font-bold text-lg text-gray-800 leading-snug group-hover:text-green-accent transition-colors duration-200 mb-3">
                    {title}
                  </h2>
                </div>
                <span class="text-xs font-semibold text-[#2cb563] group-hover:underline flex items-center gap-1 mt-4">
                  Read Article
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                </span>
              </div>
            </a>
          );
        })}
      </div>
    </main>

    <Footer />
  </body>
</html>
