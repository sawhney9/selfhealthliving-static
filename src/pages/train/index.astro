---
import Layout from '../../layouts/Layout.astro';

// Fetch all markdown posts under src/content/train
const postsMap = import.meta.glob('../../content/train/*.md', { eager: true });
const posts = Object.values(postsMap);

// Sort posts by date descending
const sortedPosts = posts.sort((a, b) => {
  return new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime();
});

// Categories map helper for client filtering
const getCategoriesForPost = (post) => {
  const slug = post.frontmatter.slug;
  if (slug === 'strength-training-after-40') return ['strength', 'longevity'];
  if (slug === 'meditation-practice-2026') return ['recovery'];
  if (slug === 'genetics-longevity') return ['longevity', 'recovery'];
  if (slug === 'decoding-blood-sugar') return ['strength', 'longevity'];
  return ['recovery'];
};
---

<Layout title="Train: Strength & Recovery | Self Health Living" currentPillar="train">
  <div class="py-12 px-6 md:px-12 max-w-6xl mx-auto w-full">
    <!-- Header Section -->
    <div class="border-b border-white/5 pb-8 mb-12 text-center md:text-left relative">
      <div class="absolute -top-12 -left-12 w-24 h-24 bg-green-accent/5 rounded-full blur-2xl"></div>
      <span class="text-xs font-bold uppercase tracking-widest text-green-accent">Content Pillar</span>
      <h1 class="font-display font-extrabold text-4xl sm:text-5xl text-white mt-2 mb-4">
        Train Smarter. Age Stronger.
      </h1>
      <p class="text-gray-400 text-sm sm:text-base max-w-xl leading-relaxed">
        Science-backed training guides, resistance protocols, muscle retention research, and recovery recommendations.
      </p>
    </div>

    <!-- Interactive Category Filter Tabs -->
    <div class="flex flex-wrap items-center gap-2 mb-10 pb-4 border-b border-white/5" id="train-filters">
      <button data-filter="all" class="filter-btn px-4 py-1.5 rounded-full text-xs font-semibold bg-green-accent text-[#14171a] border border-green-accent cursor-pointer transition-all duration-300">
        All Articles
      </button>
      <button data-filter="strength" class="filter-btn px-4 py-1.5 rounded-full text-xs font-semibold bg-white/5 text-gray-400 border border-white/5 hover:text-white cursor-pointer transition-all duration-300">
        Strength & Muscle
      </button>
      <button data-filter="recovery" class="filter-btn px-4 py-1.5 rounded-full text-xs font-semibold bg-white/5 text-gray-400 border border-white/5 hover:text-white cursor-pointer transition-all duration-300">
        Sleep & Recovery
      </button>
      <button data-filter="longevity" class="filter-btn px-4 py-1.5 rounded-full text-xs font-semibold bg-white/5 text-gray-400 border border-white/5 hover:text-white cursor-pointer transition-all duration-300">
        Longevity Science
      </button>
    </div>

    <!-- Articles Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="articles-grid">
      {sortedPosts.map((post) => {
        const { title, date, featured_image, slug } = post.frontmatter;
        const formattedDate = date ? new Date(date).toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'long',
          day: 'numeric'
        }) : '';
        
        const cats = getCategoriesForPost(post);
        
        return (
          <a 
            href={`/train/${slug}/`}
            data-categories={cats.join(',')}
            class="article-card group flex flex-col glass-card overflow-hidden hover:border-green-accent/30 transition-all duration-300 hover:-translate-y-1 transform opacity-100 scale-100"
          >
            {/* Image */}
            <div class="w-full aspect-[16/10] overflow-hidden bg-[#1e2226]/50 border-b border-white/5 relative">
              {featured_image ? (
                <img 
                  src={featured_image} 
                  alt={title} 
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center text-gray-600 bg-[#1e2226]">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                </div>
              )}
            </div>
            
            {/* Content */}
            <div class="p-6 flex-grow flex flex-col justify-between">
              <div>
                <time datetime={date} class="text-[10px] font-bold text-gray-500 uppercase tracking-widest block mb-2">
                  {formattedDate}
                </time>
                <h2 class="font-display font-bold text-base sm:text-lg text-white leading-snug group-hover:text-green-accent transition-colors duration-200 mb-3">
                  {title}
                </h2>
              </div>
              <span class="text-xs font-semibold text-green-accent group-hover:underline flex items-center gap-1 mt-4">
                Read Article
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</Layout>

<script>
  function initFilters() {
    const filterContainer = document.getElementById('train-filters');
    if (!filterContainer) return;
    
    const buttons = filterContainer.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.article-card');
    
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.getAttribute('data-filter');
        
        // Update button styles
        buttons.forEach(b => {
          b.className = 'filter-btn px-4 py-1.5 rounded-full text-xs font-semibold bg-white/5 text-gray-400 border border-white/5 hover:text-white cursor-pointer transition-all duration-300';
        });
        
        if (filter === 'all') {
          btn.className = 'filter-btn px-4 py-1.5 rounded-full text-xs font-semibold bg-green-accent text-[#14171a] border border-green-accent cursor-pointer transition-all duration-300';
        } else {
          btn.className = 'filter-btn px-4 py-1.5 rounded-full text-xs font-semibold bg-green-accent/20 text-green-accent border border-green-accent/30 cursor-pointer transition-all duration-300';
        }
        
        // Filter cards with animations
        cards.forEach(card => {
          const cardCats = card.getAttribute('data-categories').split(',');
          const matches = filter === 'all' || cardCats.includes(filter);
          
          if (matches) {
            card.classList.remove('hidden');
            setTimeout(() => {
              card.classList.remove('opacity-0', 'scale-95');
              card.classList.add('opacity-100', 'scale-100');
            }, 10);
          } else {
            card.classList.add('opacity-0', 'scale-95');
            card.classList.remove('opacity-100', 'scale-100');
            setTimeout(() => {
              card.classList.add('hidden');
            }, 300);
          }
        });
      });
    });
  }

  // Run on initial load
  initFilters();
  // Run on view transition page loads
  document.addEventListener('astro:page-load', initFilters);
</script>
