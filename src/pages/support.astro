  <!-- JavaScript Accordion & Scroll spy logic -->
  <script>
    function initSupport() {
      // 1. Accordion Toggle
      const items = document.querySelectorAll('.faq-item');
      items.forEach(item => {
        const trigger = item.querySelector('.faq-trigger');
        const content = item.querySelector('.faq-content') as HTMLElement;
        const icon = item.querySelector('.faq-icon');
        
        if (!trigger || !content || !icon) return;
        
        trigger.addEventListener('click', () => {
          const isOpen = item.classList.contains('faq-open');
          
          // Close all other items (accordion behavior)
          items.forEach(other => {
            if (other !== item && other.classList.contains('faq-open')) {
              other.classList.remove('faq-open');
              const otherContent = other.querySelector('.faq-content') as HTMLElement;
              const otherIcon = other.querySelector('.faq-icon');
              if (otherContent) {
                otherContent.style.maxHeight = '0px';
                otherContent.style.opacity = '0';
              }
              if (otherIcon) {
                otherIcon.textContent = '+';
                otherIcon.classList.remove('rotate-45', 'text-green-accent');
              }
            }
          });
          
          if (isOpen) {
            item.classList.remove('faq-open');
            content.style.maxHeight = '0px';
            content.style.opacity = '0';
            icon.textContent = '+';
            icon.classList.remove('rotate-45', 'text-green-accent');
          } else {
            item.classList.add('faq-open');
            content.style.maxHeight = content.scrollHeight + 'px';
            content.style.opacity = '1';
            icon.textContent = '×';
            icon.classList.add('rotate-45', 'text-green-accent');
          }
        });
      });

      // 2. Smooth Scroll for hero and sidebar quick links
      const scrollLinks = document.querySelectorAll('.shl-hero-link, .sidebar-link');
      scrollLinks.forEach(link => {
        link.addEventListener('click', (e) => {
          const href = link.getAttribute('href');
          if (!href || !href.startsWith('#')) return;
          const target = document.querySelector(href);
          if (target) {
            e.preventDefault();
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            
            // Push state to address bar
            history.pushState(null, '', href);
          }
        });
      });

      // 3. Scroll spy highlight for sidebar link active status
      const sections = document.querySelectorAll('.support-section');
      const sidebarLinks = document.querySelectorAll('.sidebar-link');

      function scrollSpy() {
        let currentSectionId = '';
        const scrollPosition = window.scrollY + 120; // offset

        sections.forEach(section => {
          const secEl = section as HTMLElement;
          const top = secEl.offsetTop;
          const height = secEl.offsetHeight;
          if (scrollPosition >= top && scrollPosition < top + height) {
            currentSectionId = section.getAttribute('id') || '';
          }
        });

        sidebarLinks.forEach(link => {
          const href = link.getAttribute('href');
          if (href === '#' + currentSectionId) {
            link.setAttribute('data-active', 'true');
          } else {
            link.removeAttribute('data-active');
          }
        });
      }

      window.addEventListener('scroll', scrollSpy);
      scrollSpy(); // Initial call
    }

    // astro:page-load fires on initial load AND view transitions — use it exclusively
    // (calling initSupport() directly too would double-bind every listener, making
    // accordions open then instantly close on the same click)
    document.addEventListener('astro:page-load', initSupport);

    // Feature request form
    function initFeatureRequest() {
      const form = document.getElementById('feature-request-form') as HTMLFormElement | null;
      const successMsg = document.getElementById('feature-success-msg');
      if (!form || !successMsg) return;

      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const name = (document.getElementById('feature-name') as HTMLInputElement)?.value.trim();
        const idea = (document.getElementById('feature-idea') as HTMLTextAreaElement)?.value.trim();
        if (!idea) return;

        const subject = encodeURIComponent('Feature Request: SelfHealth App');
        const body = encodeURIComponent(`${name ? 'From: ' + name + '\n\n' : ''}Feature idea:\n${idea}`);
        window.location.href = `mailto:support@selfhealthliving.com?subject=${subject}&body=${body}`;

        form.classList.add('hidden');
        successMsg.classList.remove('hidden');
      });
    }

    document.addEventListener('astro:page-load', initFeatureRequest);
  </script>
