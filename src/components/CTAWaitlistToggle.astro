---
// Status prop can be 'waitlist' or 'released'
const { status = "waitlist" } = Astro.props;
---

<div class="w-full max-w-md mx-auto" id="cta-block">
  <!-- Interactive State Selector (for demonstration & easy testing) -->
  <div class="flex justify-end mb-4">
    <div class="inline-flex rounded-full p-1 bg-white/5 border border-white/10 text-xs">
      <button 
        id="btn-state-waitlist" 
        class="px-3 py-1 rounded-full text-white bg-green-accent/20 border border-green-accent/30 font-semibold cursor-pointer transition-all duration-300"
      >
        Waitlist Mode
      </button>
      <button 
        id="btn-state-store" 
        class="px-3 py-1 rounded-full text-gray-400 hover:text-white cursor-pointer transition-all duration-300"
      >
        App Store Mode
      </button>
    </div>
  </div>

  <!-- STATE 1: Email Waitlist Capture -->
  <div id="waitlist-container" class="transition-all duration-300 transform scale-100 opacity-100">
    <form id="waitlist-form" class="flex flex-col sm:flex-row gap-3">
      <div class="relative flex-grow">
        <input 
          type="email" 
          required 
          placeholder="Enter your email address" 
          class="w-full px-5 py-3.5 rounded-full bg-[#1e2226]/80 border border-white/10 focus:border-green-accent focus:outline-none text-white text-sm placeholder-gray-500 transition-colors duration-200"
        />
      </div>
      <button 
        type="submit" 
        class="px-6 py-3.5 bg-green-accent hover:bg-green-accent-hover text-[#14171a] font-semibold rounded-full text-sm shadow-[0_0_20px_rgba(63,209,122,0.25)] hover:shadow-[0_0_25px_rgba(63,209,122,0.45)] hover:-translate-y-0.5 transition-all duration-300 cursor-pointer whitespace-nowrap"
      >
        Join the Waitlist
      </button>
    </form>
    <p id="waitlist-success" class="text-xs text-green-accent mt-3 hidden flex items-center gap-1.5 justify-center sm:justify-start">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      You have successfully joined the waitlist! We will notify you on launch.
    </p>
  </div>

  <!-- STATE 2: App Store Download Badges -->
  <div id="store-container" class="hidden transition-all duration-300 transform scale-95 opacity-0 flex flex-row items-center justify-center gap-4">
    <!-- App Store Badge -->
    <a 
      href="#" 
      class="flex items-center gap-3 px-5 py-2.5 bg-black hover:bg-black/90 border border-white/10 rounded-xl hover:border-green-accent transition-all duration-300 group hover:-translate-y-0.5 shadow-lg"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white group-hover:text-green-accent transition-colors duration-300" viewBox="0 0 305 305" fill="currentColor">
        <path d="M150.7 0C67.5 0 0 67.5 0 150.7c0 83.3 67.5 150.7 150.7 150.7 83.3 0 150.7-67.5 150.7-150.7C301.4 67.5 233.9 0 150.7 0zm43.3 227c-3.1 5.3-7.5 10.4-12.7 14.8-10.9 9.1-23.7 13.9-38.3 14-14.7.1-28.7-4.8-41.9-14.8-13.2-10-21-22.9-23.4-38.6-2.4-15.6.8-30.8 9.5-45.5 8.7-14.8 21.6-25 38.6-30.4 17-5.4 33.7-4.1 49.8 3.9 16.1 8.1 26.8 20.3 32 36.8-16 6.7-28.2 16.9-36.5 30.6-8.3 13.7-11 28.5-8.1 44.4 2.9 15.9 10.1 27.5 21 34.8zm2.2-123c-8.9.2-17.3-3.1-25.1-10-7.8-6.9-12.2-15.3-13.1-25.2-.9-9.9 2-19.1 8.7-27.6 6.7-8.5 15.2-14.1 25.5-16.7 10.3-2.6 19.8-1.5 28.5 3.3 8.7 4.8 14.9 11.7 18.6 20.7 3.7 9 3.6 18.2-.3 27.6-3.9 9.4-10.7 17.1-20.3 23-8.6 5.3-15.9 7.7-22.5 7.9z"/>
      </svg>
      <div class="text-left leading-none">
        <span class="text-[9px] uppercase tracking-wider text-gray-500 block mb-0.5">Download on the</span>
        <span class="text-sm font-semibold font-display text-white">App Store</span>
      </div>
    </a>

    <!-- Google Play Badge -->
    <a 
      href="#" 
      class="flex items-center gap-3 px-5 py-2.5 bg-black hover:bg-black/90 border border-white/10 rounded-xl hover:border-green-accent transition-all duration-300 group hover:-translate-y-0.5 shadow-lg"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white group-hover:text-green-accent transition-colors duration-300" viewBox="0 0 512 512" fill="currentColor">
        <path d="M325.3 234.3L104.6 14l280.8 161.2-60.1 59.1zM47 0C34 6.8 25.3 19.2 25.3 35.3v441.3c0 16.1 8.7 28.5 21.7 35.3l256.6-256L47 0zm425.2 225.6l-58 33.3-60.1-59.1L472.2 286c12.3-7 19.8-19.5 19.8-35.3s-7.5-28.3-19.8-35.3zM325.3 277.7l60.1 59.1L104.6 498l220.7-220.3z"/>
      </svg>
      <div class="text-left leading-none">
        <span class="text-[9px] uppercase tracking-wider text-gray-500 block mb-0.5">Get it on</span>
        <span class="text-sm font-semibold font-display text-white">Google Play</span>
      </div>
    </a>
  </div>
</div>

<script>
  const btnWaitlist = document.getElementById('btn-state-waitlist');
  const btnStore = document.getElementById('btn-state-store');
  const containerWaitlist = document.getElementById('waitlist-container');
  const containerStore = document.getElementById('store-container');
  const form = document.getElementById('waitlist-form');
  const successMsg = document.getElementById('waitlist-success');

  if (btnWaitlist && btnStore && containerWaitlist && containerStore) {
    btnWaitlist.addEventListener('click', () => {
      // Toggle button active styling
      btnWaitlist.className = 'px-3 py-1 rounded-full text-white bg-green-accent/20 border border-green-accent/30 font-semibold cursor-pointer transition-all duration-300';
      btnStore.className = 'px-3 py-1 rounded-full text-gray-400 hover:text-white cursor-pointer transition-all duration-300';
      
      // Animate transition
      containerStore.classList.add('hidden', 'scale-95', 'opacity-0');
      containerWaitlist.classList.remove('hidden');
      setTimeout(() => {
        containerWaitlist.classList.remove('scale-95', 'opacity-0');
        containerWaitlist.classList.add('scale-100', 'opacity-100');
      }, 50);
    });

    btnStore.addEventListener('click', () => {
      // Toggle button active styling
      btnStore.className = 'px-3 py-1 rounded-full text-white bg-green-accent/20 border border-green-accent/30 font-semibold cursor-pointer transition-all duration-300';
      btnWaitlist.className = 'px-3 py-1 rounded-full text-gray-400 hover:text-white cursor-pointer transition-all duration-300';
      
      // Animate transition
      containerWaitlist.classList.add('hidden', 'scale-95', 'opacity-0');
      containerStore.classList.remove('hidden');
      setTimeout(() => {
        containerStore.classList.remove('scale-95', 'opacity-0');
        containerStore.classList.add('scale-100', 'opacity-100');
      }, 50);
    });
  }

  if (form && successMsg) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const input = form.querySelector('input');
      if (input && input.value) {
        successMsg.classList.remove('hidden');
        input.value = '';
        setTimeout(() => {
          successMsg.classList.add('hidden');
        }, 5000);
      }
    });
  }
</script>
