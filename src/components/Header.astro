---
const { currentPillar } = Astro.props;
---

<header class="w-full py-4 px-6 md:px-12 flex items-center justify-between border-b border-black/6 backdrop-blur-md sticky top-0 z-50 bg-[#F7FAF8]/85">
  <div class="flex items-center gap-3">
    <a href="/" class="flex items-center gap-2.5 group">
      <div class="w-9 h-9 rounded-full bg-white border border-black/8 flex items-center justify-center shadow-sm group-hover:scale-105 group-hover:border-green-accent/30 transition-all duration-300 overflow-hidden">
        <img src="/images/brand/logo-actual.png" alt="SelfHealth Living Logo" class="w-full h-full object-cover scale-110" />
      </div>
      <span class="font-display font-bold text-xl tracking-tight text-slate-900 group-hover:text-green-accent transition-colors duration-300">
        SelfHealth<span class="text-green-accent">Living</span>
      </span>
    </a>
  </div>

  <nav class="hidden md:flex items-center gap-8 text-sm font-semibold tracking-wide">
    <a
      href="/#features"
      class="text-slate-500 hover:text-slate-900 transition-colors duration-200"
    >
      Features
    </a>
    <a
      href="/about"
      class={`transition-colors duration-200 ${currentPillar === 'about' ? 'text-green-accent font-bold' : 'text-slate-500 hover:text-slate-900'}`}
    >
      About
    </a>
    <a
      href="/train"
      class={`transition-colors duration-200 ${currentPillar === 'train' ? 'text-green-accent font-bold' : 'text-slate-500 hover:text-slate-900'}`}
    >
      Train
    </a>
    <a
      href="/fuel"
      class={`transition-colors duration-200 ${currentPillar === 'fuel' ? 'text-green-accent font-bold' : 'text-slate-500 hover:text-slate-900'}`}
    >
      Fuel
    </a>
  </nav>

  <div class="flex items-center gap-4">
    <a
      href="#waitlist"
      class="hidden sm:inline-flex items-center justify-center px-5 py-2.5 text-xs font-bold text-white bg-green-accent hover:bg-green-accent-hover rounded-full transition-all duration-300 shadow-sm hover:shadow-[0_6px_18px_rgba(0,163,108,0.28)] hover:-translate-y-0.5"
    >
      Join Waitlist
    </a>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-slate-600 hover:text-slate-900 focus:outline-none cursor-pointer"
      aria-label="Toggle Menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16m-7 6h7" />
      </svg>
    </button>
  </div>
</header>

<!-- Mobile Navigation Overlay -->
<div
  id="mobile-menu-overlay"
  class="fixed inset-0 bg-[#F7FAF8]/98 z-40 flex flex-col items-center justify-center gap-8 text-2xl font-display font-medium translate-x-full transition-transform duration-300 md:hidden"
>
  <a href="/#features" class="text-slate-700 hover:text-slate-950 transition-colors duration-200 mobile-nav-link">Features</a>
  <a href="/about" class="text-slate-700 hover:text-slate-950 transition-colors duration-200 mobile-nav-link">About</a>
  <a href="/train" class="text-slate-700 hover:text-slate-950 transition-colors duration-200 mobile-nav-link">Train</a>
  <a href="/fuel" class="text-slate-700 hover:text-slate-950 transition-colors duration-200 mobile-nav-link">Fuel</a>
  <a href="/support" class="text-slate-500 hover:text-slate-700 transition-colors duration-200 mobile-nav-link text-lg">Support</a>
  <a
    href="#waitlist"
    class="px-8 py-3 text-sm font-bold text-white bg-green-accent hover:bg-green-accent-hover rounded-full transition-all duration-300 mobile-nav-link"
  >
    Join Waitlist
  </a>
</div>

<script>
  function initMobileMenu() {
    const menuBtn = document.getElementById('mobile-menu-btn');
    const overlay = document.getElementById('mobile-menu-overlay');
    const navLinks = document.querySelectorAll('.mobile-nav-link');

    if (menuBtn && overlay) {
      overlay.classList.add('translate-x-full');
      menuBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16m-7 6h7" /></svg>`;

      menuBtn.addEventListener('click', () => {
        overlay.classList.toggle('translate-x-full');
        const isClosed = overlay.classList.contains('translate-x-full');
        menuBtn.innerHTML = isClosed
          ? `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16m-7 6h7" /></svg>`
          : `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>`;
      });

      navLinks.forEach(link => {
        link.addEventListener('click', () => {
          overlay.classList.add('translate-x-full');
          menuBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16m-7 6h7" /></svg>`;
        });
      });
    }
  }

  document.addEventListener('astro:page-load', initMobileMenu);
</script>
