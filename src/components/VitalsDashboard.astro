---
---

<div class="glass-card p-6 md:p-8 w-full max-w-lg mx-auto shadow-2xl relative overflow-hidden group animate-float">
  <!-- Glowing background effect -->
  <div class="absolute -top-16 -right-16 w-32 h-32 rounded-full bg-green-accent/10 blur-3xl group-hover:bg-green-accent/20 transition-all duration-500"></div>

  <!-- Header -->
  <div class="flex items-center justify-between border-b border-white/5 pb-4 mb-6">
    <div class="flex items-center gap-2">
      <div class="w-2.5 h-2.5 rounded-full bg-green-accent animate-pulse"></div>
      <span class="text-xs uppercase tracking-wider text-gray-400 font-semibold">Live Vitals Sync</span>
    </div>
    <span class="text-xs text-gray-500 font-medium">Updated 2m ago</span>
  </div>

  <!-- Centerpiece: Vitals Score Radial -->
  <div class="flex flex-col sm:flex-row items-center gap-8 mb-8">
    <div class="relative w-36 h-36 flex items-center justify-center">
      <!-- Radial progress SVG -->
      <svg class="w-full h-full transform -rotate-90">
        <circle 
          cx="72" 
          cy="72" 
          r="62" 
          class="stroke-white/5" 
          stroke-width="8" 
          fill="transparent" 
        />
        <circle 
          cx="72" 
          cy="72" 
          r="62" 
          class="stroke-green-accent" 
          stroke-width="8" 
          fill="transparent" 
          stroke-dasharray="390" 
          stroke-dashoffset="35"
          stroke-linecap="round"
        />
      </svg>
      <div class="absolute flex flex-col items-center justify-center text-center">
        <span class="text-4xl font-display font-extrabold text-white">92</span>
        <span class="text-[10px] uppercase tracking-widest text-gray-400 font-semibold">Vitals Score</span>
      </div>
    </div>

    <!-- Trend description -->
    <div class="text-center sm:text-left">
      <div class="inline-flex items-center gap-1 px-2.5 py-1 bg-green-accent/10 border border-green-accent/20 text-green-accent rounded-full text-xs font-semibold mb-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 10l7-7m0 0l7 7m-7-7v18" />
        </svg>
        Optimal (+3% vs last week)
      </div>
      <h3 class="text-lg font-display font-bold text-white mb-1">Your recovery is peaked</h3>
      <p class="text-xs text-gray-400 leading-relaxed max-w-xs">
        HRV and deep sleep are elevated. Your body has adapted well to yesterday's training stress.
      </p>
    </div>
  </div>

  <!-- Metrics Grid -->
  <div class="grid grid-cols-2 gap-4">
    <!-- HRV -->
    <div class="p-4 bg-white/3 border border-white/5 rounded-xl flex flex-col justify-between hover:border-white/10 transition-colors duration-200">
      <span class="text-[10px] uppercase tracking-wider text-gray-400 font-semibold mb-1">HRV (Avg)</span>
      <div class="flex items-baseline justify-between">
        <span class="text-xl font-display font-bold text-white">78<span class="text-xs text-gray-500 font-normal ml-0.5">ms</span></span>
        <span class="text-xs text-green-accent font-medium flex items-center gap-0.5">
          &uarr; 8ms
        </span>
      </div>
    </div>

    <!-- Resting HR -->
    <div class="p-4 bg-white/3 border border-white/5 rounded-xl flex flex-col justify-between hover:border-white/10 transition-colors duration-200">
      <span class="text-[10px] uppercase tracking-wider text-gray-400 font-semibold mb-1">Resting HR</span>
      <div class="flex items-baseline justify-between">
        <span class="text-xl font-display font-bold text-white">54<span class="text-xs text-gray-500 font-normal ml-0.5">bpm</span></span>
        <span class="text-xs text-green-accent font-medium flex items-center gap-0.5">
          &darr; 2bpm
        </span>
      </div>
    </div>

    <!-- Sleep -->
    <div class="p-4 bg-white/3 border border-white/5 rounded-xl flex flex-col justify-between hover:border-white/10 transition-colors duration-200">
      <span class="text-[10px] uppercase tracking-wider text-gray-400 font-semibold mb-1">Sleep Score</span>
      <div class="flex items-baseline justify-between">
        <span class="text-xl font-display font-bold text-white">88<span class="text-xs text-gray-500 font-normal ml-0.5">/100</span></span>
        <span class="text-xs text-green-accent font-medium flex items-center gap-0.5">
          &uarr; 5%
        </span>
      </div>
    </div>

    <!-- Glucose -->
    <div class="p-4 bg-white/3 border border-white/5 rounded-xl flex flex-col justify-between hover:border-white/10 transition-colors duration-200">
      <span class="text-[10px] uppercase tracking-wider text-gray-400 font-semibold mb-1">Glucose</span>
      <div class="flex items-baseline justify-between">
        <span class="text-xl font-display font-bold text-white">86<span class="text-xs text-gray-500 font-normal ml-0.5">mg/dL</span></span>
        <span class="text-xs text-green-accent font-medium flex items-center gap-0.5">
          &darr; 4mg
        </span>
      </div>
    </div>

    <!-- Strength Signal -->
    <div class="col-span-2 p-4 bg-white/3 border border-white/5 rounded-xl flex flex-col justify-between hover:border-white/10 transition-colors duration-200">
      <div class="flex items-center justify-between mb-2">
        <span class="text-[10px] uppercase tracking-wider text-gray-400 font-semibold">Strength Capacity Signal</span>
        <span class="text-xs text-green-accent font-medium flex items-center gap-0.5">
          &uarr; 4% (Peak Recovery)
        </span>
      </div>
      <div class="flex items-baseline gap-2 mb-2">
        <span class="text-2xl font-display font-bold text-white">104%</span>
        <span class="text-xs text-gray-500">of baseline capacity</span>
      </div>
      <!-- SVG sparkline representing strength capacity progress -->
      <svg class="w-full h-8 text-green-accent overflow-visible" viewBox="0 0 300 30" fill="none">
        <path 
          d="M0 20 Q 30 15, 60 25 T 120 10 T 180 22 T 240 5 T 300 2" 
          stroke="currentColor" 
          stroke-width="2" 
          fill="none" 
        />
        <path 
          d="M0 20 Q 30 15, 60 25 T 120 10 T 180 22 T 240 5 T 300 2 L 300 30 L 0 30 Z" 
          fill="url(#sparkline-grad)" 
          opacity="0.1" 
        />
        <!-- Gradient definition -->
        <defs>
          <linearGradient id="sparkline-grad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="var(--color-green-accent)" />
            <stop offset="100%" stop-color="var(--color-green-accent)" stop-opacity="0" />
          </linearGradient>
        </defs>
      </svg>
    </div>
  </div>
</div>
