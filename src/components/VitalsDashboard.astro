---
// src/components/VitalsDashboard.astro
---

<div class="w-full max-w-5xl mx-auto flex flex-col lg:flex-row items-center gap-16 py-8">

  <!-- Left Side: Feature List -->
  <div class="w-full lg:w-1/2 text-left flex flex-col gap-6" data-reveal="fade">
    <div class="inline-flex items-center gap-1.5 px-3 py-1 bg-cyan-accent/10 border border-cyan-accent/25 rounded-full text-[11px] font-bold text-cyan-accent uppercase tracking-wider w-fit">
      <span class="w-1.5 h-1.5 rounded-full bg-cyan-accent animate-pulse"></span>
      Biometric Analytics
    </div>

    <h3 class="font-display font-extrabold text-2xl sm:text-4xl text-slate-900 tracking-tight leading-tight">
      Continuous HRV, Sleep &amp; Resting Heart Rate Sync
    </h3>

    <p class="text-sm sm:text-base text-slate-500 leading-relaxed">
      SelfHealth connects directly to your health data, importing every heartbeat and sleep phase. We analyze raw data trends to calculate your daily recovery index without making you open complex dashboards.
    </p>

    <!-- Key Metrics Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-2">
      <div class="stat-card p-4 hover:border-cyan-accent/25 transition-all duration-300">
        <span class="text-xs font-bold font-display text-slate-900 block mb-1">HRV Trends</span>
        <p class="text-xs text-slate-500 leading-relaxed">Tracks root-mean-square (rMSSD) deviations to gauge autonomic nervous system strain.</p>
      </div>

      <div class="stat-card p-4 hover:border-green-accent/25 transition-all duration-300">
        <span class="text-xs font-bold font-display text-slate-900 block mb-1">Circadian Stability</span>
        <p class="text-xs text-slate-500 leading-relaxed">Measures bedtime variability and sleep latency to lock in your biological clock.</p>
      </div>

      <div class="stat-card p-4 hover:border-amber-accent/25 transition-all duration-300">
        <span class="text-xs font-bold font-display text-slate-900 block mb-1">Heart Rate Recovery</span>
        <p class="text-xs text-slate-500 leading-relaxed">Monitors how fast your heart rate returns to baseline after high-intensity training intervals.</p>
      </div>

      <div class="stat-card p-4 hover:border-blue-400/25 transition-all duration-300">
        <span class="text-xs font-bold font-display text-slate-900 block mb-1">Resting Heart Rate</span>
        <p class="text-xs text-slate-500 leading-relaxed">Integrates waking pulse counts to verify cardiovascular adaptations over time.</p>
      </div>
    </div>
  </div>

  <!-- Right Side: Dual Floating Phone Layout -->
  <div class="w-full lg:w-1/2 flex items-center justify-center relative min-h-[460px] sm:min-h-[540px]" data-reveal="scale" data-reveal-delay="150">
    <!-- Ambient Glow -->
    <div class="absolute w-[300px] h-[300px] bg-cyan-accent/6 rounded-full blur-[90px] pointer-events-none animate-drift"></div>

    <!-- Phone 1 (Sleep Trends) — Background -->
    <div class="absolute left-[8%] sm:left-[12%] w-[190px] sm:w-[240px] h-[380px] sm:h-[480px] z-10 origin-bottom-right rotate-[-8deg] -translate-y-4 hover:rotate-[-4deg] transition-all duration-500 phone-frame phone-frame-sm animate-float-slow">
      <div class="phone-glare"></div>
      <div class="absolute top-2 left-1/2 -translate-x-1/2 w-16 h-3 bg-black rounded-full z-30 flex items-center justify-between px-1.5">
        <div class="w-0.5 h-0.5 rounded-full bg-slate-900"></div>
        <div class="w-4 h-0.5 bg-slate-900 rounded-full"></div>
      </div>
      <img src="/images/app/app_screen_8.png" alt="SelfHealth Sleep Trends Screen" class="w-full h-full object-cover" />
    </div>

    <!-- Phone 2 (Resting HR) — Foreground -->
    <div class="absolute right-[8%] sm:right-[12%] w-[190px] sm:w-[240px] h-[380px] sm:h-[480px] z-20 origin-bottom-left rotate-[6deg] translate-y-6 hover:rotate-[2deg] transition-all duration-500 shadow-[0_30px_70px_-10px_rgba(0,0,0,0.18)] phone-frame phone-frame-sm animate-float">
      <div class="phone-glare"></div>
      <div class="absolute top-2 left-1/2 -translate-x-1/2 w-16 h-3 bg-black rounded-full z-30 flex items-center justify-between px-1.5">
        <div class="w-0.5 h-0.5 rounded-full bg-slate-900"></div>
        <div class="w-4 h-0.5 bg-slate-900 rounded-full"></div>
      </div>
      <img src="/images/app/app_screen_7.png" alt="SelfHealth Resting Heart Rate Sync Screen" class="w-full h-full object-cover" />
    </div>

    <!-- Floating Hotspot Labels -->
    <div class="absolute top-[15%] left-[2%] bg-white border border-black/8 shadow-md px-3 py-1.5 rounded-lg z-30 pointer-events-none text-left hidden sm:block">
      <span class="text-[9px] uppercase tracking-wider text-cyan-accent block font-bold">Circadian Rhythm</span>
      <span class="text-[10px] text-slate-900 font-medium">92% Sleep consistency</span>
    </div>

    <div class="absolute bottom-[20%] right-[0%] bg-white border border-black/8 shadow-md px-3 py-1.5 rounded-lg z-30 pointer-events-none text-left hidden sm:block">
      <span class="text-[9px] uppercase tracking-wider text-green-accent block font-bold">Autonomic Balance</span>
      <span class="text-[10px] text-slate-900 font-medium">HRV up 14% this week</span>
    </div>
  </div>

</div>
