---
// src/components/AppShowcase.astro

const screens = [
  {
    id: "vitals",
    label: "Biometric Dashboard",
    title: "Universal Vitals Scoring",
    description: "Sync all your wearables — HRV, Sleep, Resting HR — into one unified recovery score. No complex spreadsheets, just clear, actionable daily guidance.",
    image: "/images/app/app_screen_1.png",
    glowColor: "rgba(0, 163, 108, 0.15)",
    accent: "green"
  },
  {
    id: "fitness",
    label: "Fitness & Workouts",
    title: "Training Load & Workouts",
    description: "Plan workouts, log sets, and track your Training Load. Monitor whether your exercises are optimal or overreaching so you can adapt for active recovery.",
    image: "/images/app/fitness_workouts.png",
    glowColor: "rgba(214, 158, 46, 0.15)",
    accent: "amber"
  },
  {
    id: "bloodwork",
    label: "Blood Markers",
    title: "Total Cholesterol & Biomarkers",
    description: "Track cardiovascular health and nutrient markers in context. View history charts, optimal clinical zones, and reference ranges at a glance.",
    image: "/images/app/blood_cholesterol.png",
    glowColor: "rgba(239, 68, 68, 0.15)",
    accent: "red"
  },
  {
    id: "aliya",
    label: "Aliya AI Assistant",
    title: "Your Plain-English Health Translator",
    description: "Upload laboratory PDFs or raw biomarker logs. Aliya translates clinical jargon into simple, supportive feedback on what to change next.",
    image: "/images/app/stress_calm.png",
    glowColor: "rgba(0, 128, 176, 0.15)",
    accent: "cyan"
  },
  {
    id: "cycle",
    label: "Cycle & Hormone Sync",
    title: "Train With Your Hormones",
    description: "Track cycle phases to optimize strength training loads, cardiovascular targets, and nutritional needs across follicular, ovulatory, and luteal phases.",
    image: "/images/app/cycle_calendar.png",
    glowColor: "rgba(236, 72, 153, 0.15)",
    accent: "pink"
  },
];
---

<div class="w-full max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">

  <!-- Left: Phone Mockup -->
  <div class="lg:col-span-5 flex justify-center relative py-8">
    <!-- Ambient Glow -->
    <div
      id="showcase-ambient-glow"
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-[420px] rounded-full blur-[80px] opacity-60 transition-all duration-700 z-0"
      style="background-color: rgba(0, 163, 108, 0.15);"
    ></div>

    <!-- iPhone Mockup -->
    <div class="relative z-10 mx-auto border-[10px] border-[#1f242c] rounded-[3rem] w-[280px] h-[570px] sm:w-[300px] sm:h-[610px] shadow-[0_30px_70px_-10px_rgba(0,0,0,0.22)] bg-black overflow-hidden transition-transform duration-500 hover:scale-[1.02] border-t-[8px]">
      <!-- Dynamic Island -->
      <div class="absolute top-3.5 left-1/2 -translate-x-1/2 w-24 h-5 bg-black rounded-full z-30 flex items-center justify-between px-3">
        <div class="w-1.5 h-1.5 rounded-full bg-slate-900"></div>
        <div class="w-8 h-1 bg-slate-900 rounded-full"></div>
      </div>

      <!-- Side buttons -->
      <div class="absolute top-28 -left-[11px] w-[2px] h-10 bg-slate-800 rounded-r z-20"></div>
      <div class="absolute top-44 -left-[11px] w-[2px] h-14 bg-slate-800 rounded-r z-20"></div>
      <div class="absolute top-60 -left-[11px] w-[2px] h-14 bg-slate-800 rounded-r z-20"></div>
      <div class="absolute top-36 -right-[11px] w-[2px] h-18 bg-slate-800 rounded-l z-20"></div>

      <!-- Screen -->
      <div class="w-full h-full relative overflow-hidden bg-slate-950">
        <img
          id="showcase-screen-img"
          src={screens[0].image}
          alt={screens[0].title}
          class="w-full h-full object-cover transition-opacity duration-300 opacity-100"
        />
        <div class="absolute inset-0 bg-gradient-to-tr from-white/0 via-white/[0.02] to-white/0 pointer-events-none z-20"></div>
      </div>
    </div>
  </div>

  <!-- Right: Feature Selector -->
  <div class="lg:col-span-7 flex flex-col gap-5 text-left">
    <div class="mb-2">
      <span class="text-[10px] uppercase font-bold tracking-widest text-green-accent">App Interface</span>
      <h3 class="text-2xl sm:text-3xl font-display font-extrabold text-slate-900 mt-1">
        Experience SelfHealth
      </h3>
      <p class="text-xs sm:text-sm text-slate-500 mt-2 max-w-lg">
        Take a tour through our iOS application. Select a feature to view the actual app interface.
      </p>
    </div>

    <!-- Tab Buttons -->
    <div class="flex flex-col gap-3" id="showcase-tabs">
      {screens.map((screen, index) => (
        <button
          data-id={screen.id}
          data-image={screen.image}
          data-glow={screen.glowColor}
          data-accent={screen.accent}
          class={`tab-row w-full p-4 rounded-xl text-left border cursor-pointer transition-all duration-300 flex flex-col md:flex-row md:items-center justify-between gap-4 ${
            index === 0
              ? "bg-white border-green-accent/30 shadow-sm"
              : "bg-white/50 border-black/6 hover:border-black/12 hover:bg-white/80"
          }`}
        >
          <div class="max-w-md">
            <span class={`text-[10px] uppercase font-bold tracking-wider block mb-1 ${
              index === 0 ? "text-green-accent" : "text-slate-400"
            } tab-badge`}>
              {screen.label}
            </span>
            <h4 class="font-display font-bold text-slate-900 text-sm sm:text-base leading-snug">
              {screen.title}
            </h4>
            <p class={`text-xs text-slate-500 mt-1.5 leading-relaxed transition-all duration-300 ${
              index === 0 ? "opacity-100 max-h-24" : "opacity-0 max-h-0 overflow-hidden md:opacity-100 md:max-h-none"
            } tab-desc`}>
              {screen.description}
            </p>
          </div>

          <div class="hidden md:flex items-center justify-center w-8 h-8 rounded-full bg-slate-100 border border-black/5 text-slate-400 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </button>
      ))}
    </div>
  </div>
</div>

<script>
  function initShowcase() {
    const tabsContainer = document.getElementById('showcase-tabs');
    const screenImg = document.getElementById('showcase-screen-img') as HTMLImageElement;
    const ambientGlow = document.getElementById('showcase-ambient-glow');

    if (!tabsContainer || !screenImg || !ambientGlow) return;

    const tabs = tabsContainer.querySelectorAll('.tab-row');

    const accentBadgeColors: Record<string, string> = {
      green: 'text-green-accent',
      amber: 'text-amber-accent',
      red: 'text-red-500',
      cyan: 'text-cyan-accent',
      pink: 'text-pink-500',
    };

    const accentBorderColors: Record<string, string> = {
      green: 'border-green-accent/30',
      amber: 'border-amber-accent/30',
      red: 'border-red-400/30',
      cyan: 'border-cyan-accent/30',
      pink: 'border-pink-400/30',
    };

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const imageSrc = tab.getAttribute('data-image');
        const glowColor = tab.getAttribute('data-glow');
        const accent = tab.getAttribute('data-accent') || 'green';

        // Swap image
        screenImg.style.opacity = '0';
        setTimeout(() => {
          if (imageSrc) screenImg.src = imageSrc;
          screenImg.style.opacity = '1';
        }, 150);

        // Transition glow color
        if (glowColor) ambientGlow.style.backgroundColor = glowColor;

        // Reset all tabs
        tabs.forEach(t => {
          t.className = 'tab-row w-full p-4 rounded-xl text-left border bg-white/50 border-black/6 hover:border-black/12 hover:bg-white/80 cursor-pointer transition-all duration-300 flex flex-col md:flex-row md:items-center justify-between gap-4';
          const badge = t.querySelector('.tab-badge');
          if (badge) badge.className = 'text-[10px] uppercase font-bold tracking-wider block mb-1 text-slate-400 tab-badge';
          const desc = t.querySelector('.tab-desc');
          if (desc) desc.className = 'text-xs text-slate-500 mt-1.5 leading-relaxed opacity-0 max-h-0 overflow-hidden md:opacity-100 md:max-h-none tab-desc';
        });

        // Activate clicked tab
        const borderClass = accentBorderColors[accent] || 'border-green-accent/30';
        const badgeColor = accentBadgeColors[accent] || 'text-green-accent';

        tab.className = `tab-row w-full p-4 rounded-xl text-left border bg-white ${borderClass} shadow-sm cursor-pointer transition-all duration-300 flex flex-col md:flex-row md:items-center justify-between gap-4`;

        const activeBadge = tab.querySelector('.tab-badge');
        if (activeBadge) activeBadge.className = `text-[10px] uppercase font-bold tracking-wider block mb-1 ${badgeColor} tab-badge`;

        const activeDesc = tab.querySelector('.tab-desc');
        if (activeDesc) activeDesc.className = 'text-xs text-slate-500 mt-1.5 leading-relaxed opacity-100 max-h-24 transition-all duration-300 tab-desc';
      });
    });
  }

  initShowcase();
  document.addEventListener('astro:page-load', initShowcase);
</script>
