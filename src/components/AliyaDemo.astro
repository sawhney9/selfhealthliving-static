---
---

<div class="w-full max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-6 items-center bg-white border border-black/7 rounded-2xl p-6 md:p-8 shadow-[0_8px_40px_-8px_rgba(0,0,0,0.1)]">

  <!-- Left Side: Raw Lab PDF Mockup -->
  <div class="bg-slate-50 border border-black/7 rounded-xl p-5 relative overflow-hidden flex flex-col gap-4">
    <!-- Header -->
    <div class="flex items-center justify-between border-b border-black/6 pb-3">
      <div class="flex flex-col">
        <span class="text-[9px] uppercase tracking-wider text-slate-400 font-semibold">Source Document</span>
        <span class="text-xs font-bold text-slate-700 font-display">LabReport_2026_06.pdf</span>
      </div>
      <div class="px-2 py-0.5 bg-red-50 border border-red-200 rounded text-[9px] font-semibold text-red-500 uppercase tracking-wider">
        Raw Data
      </div>
    </div>

    <!-- Lab table -->
    <div class="flex flex-col gap-3.5 text-xs">
      <div class="flex items-center justify-between border-b border-black/4 pb-2.5">
        <span class="text-slate-500 font-medium">CHOLESTEROL, TOTAL</span>
        <div class="text-right">
          <span class="text-slate-800 font-bold">224 <span class="text-[10px] text-slate-400 font-normal">mg/dL</span></span>
          <span class="text-red-500 text-[10px] font-semibold block uppercase">High (&gt;200)</span>
        </div>
      </div>
      <div class="flex items-center justify-between border-b border-black/4 pb-2.5">
        <span class="text-slate-500 font-medium">TRIGLYCERIDES</span>
        <div class="text-right">
          <span class="text-slate-800 font-bold">140 <span class="text-[10px] text-slate-400 font-normal">mg/dL</span></span>
          <span class="text-green-600 text-[10px] font-semibold block uppercase">Optimal (&lt;150)</span>
        </div>
      </div>
      <div class="flex items-center justify-between border-b border-black/4 pb-2.5">
        <span class="text-slate-500 font-medium">HDL CHOLESTEROL</span>
        <div class="text-right">
          <span class="text-slate-800 font-bold">48 <span class="text-[10px] text-slate-400 font-normal">mg/dL</span></span>
          <span class="text-slate-500 text-[10px] font-semibold block uppercase">Acceptable (&gt;40)</span>
        </div>
      </div>
      <div class="flex items-center justify-between">
        <span class="text-slate-500 font-medium">LDL-C (CALCULATED)</span>
        <div class="text-right">
          <span class="text-slate-800 font-bold">148 <span class="text-[10px] text-slate-400 font-normal">mg/dL</span></span>
          <span class="text-red-500 text-[10px] font-semibold block uppercase">High (&gt;100)</span>
        </div>
      </div>
    </div>

    <!-- PDF watermark -->
    <div class="absolute bottom-2 right-2 opacity-5 pointer-events-none">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-20 w-20 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
    </div>
  </div>

  <!-- Right Side: Aliya's Plain-English Response -->
  <div class="flex flex-col gap-4">
    <div class="flex items-center gap-2.5">
      <div class="w-9 h-9 rounded-full bg-green-accent/10 border border-green-accent/25 flex items-center justify-center text-green-accent font-display font-bold text-sm shadow-sm">
        A
      </div>
      <div>
        <h4 class="text-sm font-display font-bold text-slate-900 leading-none">Aliya</h4>
        <span class="text-[10px] text-green-accent font-semibold tracking-wider uppercase">Health Assistant</span>
      </div>
    </div>

    <!-- Explanation -->
    <div class="bg-green-accent/5 border border-green-accent/12 rounded-xl p-5">
      <p class="text-sm text-slate-700 leading-relaxed mb-4">
        "Your total cholesterol and LDL ('bad' cholesterol) are slightly elevated, but your triglycerides and HDL ('good' cholesterol) are in a solid range.
      </p>
      <p class="text-sm text-slate-700 leading-relaxed mb-4">
        This isn't cause for alarm — it's a helpful signal. Instead of drastic changes, let's focus on adding more <strong class="text-slate-900">soluble fiber</strong> (like our chickpea pancake or oats) to your breakfast. Soluble fiber acts like a natural sponge in your gut, clearing LDL before it gets absorbed."
      </p>

      <div class="border-t border-black/5 pt-3 mt-3 flex items-center justify-between text-[10px] text-slate-400">
        <span class="font-medium italic">"A knowledgeable friend, not a doctor."</span>
        <span class="uppercase tracking-widest text-green-accent/80 font-bold">Educational Only</span>
      </div>
    </div>

    <!-- Arrow from PDF to Aliya on larger screens -->
    <p class="text-[11px] text-slate-400 text-center md:text-left font-medium">
      Upload any blood panel PDF &rarr; Aliya reads and explains it in plain English.
    </p>
  </div>
</div>
